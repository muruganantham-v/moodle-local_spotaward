# Copy this file to deploy_cluster.env and set values for your environment.

# Space-separated list of web nodes.
SERVERS="web1.example.com web2.example.com"

# Node used for maintenance mode and DB upgrade.
PRIMARY_SERVER="web1.example.com"

# SSH user for deploy.
DEPLOY_USER="deploy"

# Moodle root directory on each node.
REMOTE_MOODLE_DIR="/var/www/moodle"

# Optional settings.
PHP_BIN="/usr/bin/php"
PLUGIN_NAME="batchanalytics"
# PLUGIN_DIR defaults to the parent of deploy_cluster.sh
# PLUGIN_DIR="/Users/you/path/to/local/batchanalytics"
SSH_OPTS="-o BatchMode=yes -o StrictHostKeyChecking=accept-new"
# BACKUP_DIR defaults to $REMOTE_MOODLE_DIR/local/.deploy-backups
# BACKUP_DIR="/var/www/moodle/local/.deploy-backups"
